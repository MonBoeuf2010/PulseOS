# LifeIQ environment — copy to .env and fill in. NEVER commit real secrets.

# --- Core ---
ENV=development
SECRET_KEY=change-me-32-bytes-min
JWT_PRIVATE_KEY_PEM=                # EdDSA/RS256 signing key (Secrets Manager in prod)
JWT_PUBLIC_KEY_PEM=

# --- Datastores ---
DATABASE_URL=postgresql+asyncpg://pulse:pulse@db:5432/lifeiq
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://pulse:pulse@rabbitmq:5672//
OPENSEARCH_URL=http://opensearch:9200

# --- AI Gateway (model-agnostic; see backend/app/council) ---
# Default reasoning provider for the Council. Use the latest capable Claude model.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
EMBEDDING_MODEL=text-embedding-3-small   # via provider abstraction
AI_FAST_MODEL=claude-haiku-4-5-20251001  # fast-path tier

# --- Billing (Stripe) ---
# Dashboard → Products: create "LifeIQ Basic" ($5/mo) and "LifeIQ Pro" ($15/mo,
# add a yearly price too). Paste the price IDs below. Webhook secret comes from
# Dashboard → Developers → Webhooks (endpoint: https://<api-domain>/v1/billing/webhook).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=                 # price_... for Basic $5/mo
STRIPE_PRICE_MONTHLY=               # price_... for Pro monthly
STRIPE_PRICE_YEARLY=                # price_... for Pro yearly
FRONTEND_BASE_URL=http://localhost:3000   # where Stripe redirects after checkout

# --- Mobile IAP (RevenueCat → Apple/Google) ---
# RevenueCat Dashboard → Integrations → Webhooks: set the Authorization header to
# this exact value. Endpoint: https://<api-domain>/v1/iap/webhook
REVENUECAT_WEBHOOK_AUTH=

# --- Launch hardening ---
RATELIMIT_AUTH=10/minute            # per-IP cap on /auth
RATELIMIT_CHAT=20/minute            # per-IP cap on /chat
RATELIMIT_STORAGE_URI=              # blank = in-memory; set to REDIS_URL for multi-worker
FREE_DAILY_AI_LIMIT=25              # chat/council calls per free user per day
PREMIUM_DAILY_AI_LIMIT=1000
GLOBAL_DAILY_AI_SPEND_CAP_USD=50    # hard kill-switch across all users per day
UPLOAD_DIR=/data/uploads            # attachment storage (mount a volume in prod; S3 later)

# --- CORS (who may call the API) ---
# JSON array. MUST include "capacitor://localhost" or the iOS app shows blank
# screens while the website works — the #1 silent killer for wrapped apps.
# In production also add your web app origin, e.g. "https://app.YOURDOMAIN.com".
CORS_ORIGINS=["http://localhost:3000","capacitor://localhost"]

# --- Frontend ---
# The web client appends "/v1" itself, so this is the API ORIGIN only (no /v1).
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_ADSENSE_CLIENT=         # ca-pub-XXXX (Basic tier ads); blank = house upsell only
