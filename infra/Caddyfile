# Caddy = automatic HTTPS (Let's Encrypt) + reverse proxy in front of the API.
# Set API_DOMAIN in your .env (e.g. api.pulseos.app). Caddy fetches/renews TLS
# certs automatically as long as the domain's DNS A record points at this server.

{$API_DOMAIN} {
	encode gzip

	# Stripe webhooks + the SPA both need the API; everything is the backend here.
	reverse_proxy api:8000

	# Sensible security headers (the API is JSON + file downloads only).
	header {
		Strict-Transport-Security "max-age=31536000;"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}
