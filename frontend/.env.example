# Base URL of the LifeIQ API (no trailing slash). The client appends /v1 itself,
# so this is the API ORIGIN only — do NOT add /api or /v1.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# RevenueCat PUBLIC iOS key (starts with appl_). From RevenueCat dashboard →
# Project Settings → API Keys. Used only inside the native iOS app for In-App
# Purchases; blank on web (web uses Stripe). Safe to ship in the client.
NEXT_PUBLIC_REVENUECAT_IOS_KEY=

# Google AdSense client id (ca-pub-XXXX) for the ad-supported free tier; blank = no ads.
NEXT_PUBLIC_ADSENSE_CLIENT=
